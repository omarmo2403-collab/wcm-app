{
  "expo": {
    "name": "Wembley Central Masjid",
    "slug": "wcm-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wcm",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.afomsolutions.wcm",
      "supportsTablet": false,
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.afomsolutions.wcm",
      "adaptiveIcon": {
        "backgroundColor": "#159778",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.USE_EXACT_ALARM"
      ],
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "com.google.android.gms.permission.ACTIVITY_RECOGNITION",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 300
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "production",
          "smallIcons": [
            "./assets/images/notification-icon.png"
          ],
          "smallIconAccentColor": "#159778"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#159778"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is used only on this device to point the Qibla compass toward Makkah from where you are. It is never stored or shared.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "The compass uses your device's motion sensors to rotate the Qibla pointer as you turn your phone."
        }
      ],
      "./plugins/without-expo-fcm.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "wcm-mobileapp",
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.afomsolutions.wcm.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.afomsolutions.wcm.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "5113e71d-baa0-4982-8518-a5046bd470ce"
      }
    }
  }
}